generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model KnowledgeNode {
  id               String          @id @default(uuid())
  title            String
  parentId         String?
  level            Int
  sortOrder        Int
  category         String
  content          String?
  contentGenerated Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  parent           KnowledgeNode?  @relation("KnowledgeTree", fields: [parentId], references: [id])
  children         KnowledgeNode[] @relation("KnowledgeTree")
}

model ExamPaper {
  id        String     @id @default(uuid())
  title     String
  year      Int
  region    String     @default("贵州")
  type      String
  createdAt DateTime   @default(now())
  questions Question[]
}

model Question {
  id          String    @id @default(uuid())
  paperId     String
  type        String
  stem        String
  options     String?
  answer      String?
  explanation String?
  sortOrder   Int       @default(0)
  paper       ExamPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}
